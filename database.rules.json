{
  "rules": {
    "chats": {
      "$chatId": {
        "metadata": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "messages": {
          ".read": "auth != null",
          "messageId": {
            ".write": "auth != null && (data.child('senderId').val() == auth.uid || newData.child('senderId').val() == auth.uid)"
          },
          ".indexOn": ["timestamp"]
        }
      }
    },
    "userChats": {
      "$userId": {
        ".read": "$userId === auth.uid",
        ".write": "$userId === auth.uid"
      }
    }
  }
}
