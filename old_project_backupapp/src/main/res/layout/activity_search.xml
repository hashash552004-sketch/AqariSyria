<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl">

    <!-- Header with search bar -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/primary"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@android:color/transparent"
                    android:tint="@color/text_white"
                    android:contentDescription="@string/back"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/search_title"
                    android:textColor="@color/text_white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btnCompare"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_compare"
                    android:background="@android:color/transparent"
                    android:tint="@color/text_white"
                    android:contentDescription="@string/compare"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white_alpha_10"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="16dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:tint="@color/white_alpha_70"/>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="@string/search_hint_home"
                        android:textColorHint="@color/white_alpha_70"
                        android:textColor="@color/text_white"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:background="@android:color/transparent"
                        android:layout_marginStart="12dp"
                        android:inputType="text"
                        android:imeOptions="actionSearch"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Filters Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CardStyle"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section: نوع العملية -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/operation_type"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupOperation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:singleSelection="true"
                        app:selectionRequired="false"
                        app:chipSpacing="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAll"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_all"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"
                            app:checkedIconVisible="false"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipSell"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/for_sale"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRent"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/for_rent"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInvest"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/for_invest"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Section: نطاق السعر -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/price_range"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMinPrice"
                            style="@style/InputField"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="@string/price_from"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:startIconDrawable="@null">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textAlignment="viewStart" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textSize="18sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginHorizontal="4dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMaxPrice"
                            style="@style/InputField"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="@string/price_to"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:startIconDrawable="@null">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaxPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textAlignment="viewStart" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Section: المحافظة -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/governorate"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilGovernorate"
                        style="@style/InputField"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="1.5dp"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/text_hint">

                        <AutoCompleteTextView
                            android:id="@+id/etGovernorate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textAlignment="viewStart"
                            android:focusable="false"
                            android:clickable="true"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Section: نوع العقار -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/property_type"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="10dp"/>

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:singleSelection="true"
                        app:selectionRequired="false"
                        app:chipSpacing="8dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTypeAll"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/filter_all"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipApartment"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_apartment"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipVilla"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_villa"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipLand"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_land"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipHouse"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_house"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipShop"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_shop"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipWarehouse"
                            style="@style/Widget.AqariSyria.ChipChoice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/category_warehouse"
                            android:textColor="@color/text_primary"
                            app:chipBackgroundColor="@color/accent_container"
                            app:chipStrokeColor="@color/border"
                            app:chipStrokeWidth="0dp"/>

                    </com.google.android.material.chip.ChipGroup>

                    <!-- Section: غرف + مساحة -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilRooms"
                            style="@style/InputField"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:hint="@string/rooms_label"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:startIconDrawable="@drawable/ic_bedroom"
                            app:startIconTint="@color/text_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRooms"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textAlignment="viewStart" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMinArea"
                            style="@style/InputField"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:hint="@string/area_min"
                            app:boxStrokeWidth="1dp"
                            app:boxStrokeWidthFocused="1.5dp"
                            app:startIconDrawable="@drawable/ic_area"
                            app:startIconTint="@color/text_hint">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMinArea"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:textAlignment="viewStart" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <!-- Search Button -->
                    <Button
                        android:id="@+id/btnSearch"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_login_button"
                        android:text="@string/search"
                        android:textColor="@color/text_white"
                        android:textSize="@dimen/text_normal"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="false"
                        android:elevation="4dp"
                        android:drawableStart="@drawable/ic_search"
                        android:drawablePadding="@dimen/padding_small"
                        android:drawableTint="@color/text_white"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
