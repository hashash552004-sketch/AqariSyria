<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingTop="44dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@android:color/transparent"
            android:tint="@color/text_white"/>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="بحث متقدم"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View android:layout_width="40dp" android:layout_height="40dp"/>
    </LinearLayout>

    <!-- Search Input -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeWidth="0dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilSearch"
            style="@style/InputField"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ابحث عن عقار..."
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/text_hint"
            app:endIconMode="clear_text"
            app:endIconTint="@color/text_hint"
            app:boxStrokeWidth="0dp"
            app:boxStrokeWidthFocused="0dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textAlignment="viewStart" />

        </com.google.android.material.textfield.TextInputLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Filters Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Operation Type Chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نوع العملية"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupOperation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleSelection="true"
                app:selectionRequired="false"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الكل"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:checkedIconVisible="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSell"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="للبيع"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRent"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="للإيجار"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipInvest"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="استثمار"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- Price Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نطاق السعر"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMinPrice"
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:hint="من"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:startIconDrawable="@null">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textAlignment="viewStart" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="–"
                    android:textSize="18sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginHorizontal="4dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMaxPrice"
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:hint="إلى"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:startIconDrawable="@null">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMaxPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textAlignment="viewStart" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Governorate -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المحافظة"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilGovernorate"
                style="@style/InputField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:startIconDrawable="@drawable/ic_location"
                app:startIconTint="@color/text_hint">

                <AutoCompleteTextView
                    android:id="@+id/etGovernorate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textAlignment="viewStart"
                    android:focusable="false"
                    android:clickable="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Property Type -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="نوع العقار"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:singleSelection="true"
                app:selectionRequired="false"
                app:chipSpacing="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeAll"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الكل"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipApartment"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="شقة"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipVilla"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="فيلا"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLand"
                    style="@style/Widget.AqariSyria.ChipChoice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أرض"
                    android:textColor="@color/text_primary"
                    app:chipBackgroundColor="@color/surface_variant"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"/>

            </com.google.android.material.chip.ChipGroup>

            <!-- Rooms + Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRooms"
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:hint="الغرف"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:startIconDrawable="@drawable/ic_bedroom"
                    app:startIconTint="@color/text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRooms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textAlignment="viewStart" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilMinArea"
                    style="@style/InputField"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:hint="المساحة (م²)"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1.5dp"
                    app:startIconDrawable="@drawable/ic_area"
                    app:startIconTint="@color/text_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etMinArea"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textAlignment="viewStart" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- Search Button -->
            <Button
                android:id="@+id/btnSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_login_button"
                android:text="بحث"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textAllCaps="false"
                android:elevation="4dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"/>

    <!-- Count -->
    <TextView
        android:id="@+id/tvResultCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:visibility="gone"/>

    <!-- Empty -->
    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لا توجد نتائج"
        android:gravity="center"
        android:padding="32dp"
        android:textColor="@color/text_secondary"
        android:visibility="gone"/>

    <!-- Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp"
        android:paddingTop="4dp"
        android:visibility="gone"/>

</LinearLayout>
