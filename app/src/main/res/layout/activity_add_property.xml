<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:layoutDirection="rtl">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="44dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@android:color/transparent"
                android:tint="@color/text_white"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/tvStepTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="إضافة عقار"
                android:textColor="@color/text_white"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStepCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/5"
                android:textColor="#CCffffff"
                android:textSize="14sp"/>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="12dp"
            android:progress="20"
            android:progressTint="@color/text_white"
            android:progressBackgroundTint="#66ffffff"/>
    </LinearLayout>

    <!-- Step Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- STEP 1: Operation Type -->
            <LinearLayout
                android:id="@+id/step1Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="اختر نوع العملية"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="24dp"/>

                <Button
                    android:id="@+id/btnOperationSell"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="للبيع"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnOperationRent"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="للإيجار"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnOperationInvest"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="استثمار"
                    android:textSize="16sp"
                    android:gravity="center"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <!-- STEP 2: Basic Info -->
            <LinearLayout
                android:id="@+id/step2Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="معلومات أساسية"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="20dp"/>

                <!-- Property Type -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="نوع العقار" android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerPropertyType"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@drawable/bg_spinner" android:layout_marginBottom="16dp"/>

                <!-- Governorate -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="المحافظة" android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>
                <Spinner android:id="@+id/spinnerGovernorate"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@drawable/bg_spinner" android:layout_marginBottom="16dp"/>

                <!-- Region -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="المنطقة" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRegion"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Neighborhood -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="الحي" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNeighborhood"
                        android:layout_width="match_parent" android:layout_height="wrap_content"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Detailed Address -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="العنوان التفصيلي" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDetailedAddress"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="أدخل العنوان بالتفصيل"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- STEP 3: Property Details -->
            <LinearLayout
                android:id="@+id/step3Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تفاصيل المقار"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="20dp"/>

                <!-- Price -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPrice"
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="السعر $" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrice"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Area -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="المساحة (م²)" android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etArea"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="numberDecimal"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Rooms Counter -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="عدد الغرف" android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageButton android:id="@+id/btnRoomsMinus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_minus" android:background="@drawable/bg_counter_btn"/>
                    <TextView android:id="@+id/tvRoomsCount"
                        android:layout_width="48dp" android:layout_height="wrap_content"
                        android:text="1" android:textSize="18sp" android:textStyle="bold"
                        android:gravity="center" android:textColor="@color/text_primary"/>
                    <ImageButton android:id="@+id/btnRoomsPlus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_plus" android:background="@drawable/bg_counter_btn"/>
                </LinearLayout>

                <!-- Bathrooms Counter -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="عدد الحمامات" android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageButton android:id="@+id/btnBathroomsMinus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_minus" android:background="@drawable/bg_counter_btn"/>
                    <TextView android:id="@+id/tvBathroomsCount"
                        android:layout_width="48dp" android:layout_height="wrap_content"
                        android:text="1" android:textSize="18sp" android:textStyle="bold"
                        android:gravity="center" android:textColor="@color/text_primary"/>
                    <ImageButton android:id="@+id/btnBathroomsPlus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_plus" android:background="@drawable/bg_counter_btn"/>
                </LinearLayout>

                <!-- Floor Counter -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="الطابق" android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    <ImageButton android:id="@+id/btnFloorMinus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_minus" android:background="@drawable/bg_counter_btn"/>
                    <TextView android:id="@+id/tvFloorCount"
                        android:layout_width="48dp" android:layout_height="wrap_content"
                        android:text="1" android:textSize="18sp" android:textStyle="bold"
                        android:gravity="center" android:textColor="@color/text_primary"/>
                    <ImageButton android:id="@+id/btnFloorPlus"
                        android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_plus" android:background="@drawable/bg_counter_btn"/>
                </LinearLayout>

                <!-- Description -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/InputField"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:hint="وصف العقار" android:layout_marginBottom="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDescription"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:minLines="4" android:gravity="top|start"
                        android:inputType="textMultiLine"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- STEP 4: Features -->
            <LinearLayout
                android:id="@+id/step4Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المميزات"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="20dp"/>

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="false">

                    <com.google.android.material.chip.Chip android:id="@+id/chipElevator"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="مصعد" app:chipBackgroundColor="@color/primary_light"
                        app:checkedIconVisible="true"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipParking"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="موقف سيارة"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipAC"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="تكييف"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipHeating"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="تدفئة"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipGarden"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="حديقة"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipPool"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="مسبح"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipBalcony"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="شرفة"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipInternet"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="إنترنت"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipGas"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="غاز"/>
                    <com.google.android.material.chip.Chip android:id="@+id/chipFurnished"
                        style="@style/Widget.MaterialComponents.Chip.Filter"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="مفروش"/>
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- STEP 5: Images -->
            <LinearLayout
                android:id="@+id/step5Container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="صور المقار"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="20dp"/>

                <Button
                    android:id="@+id/btnAddImages"
                    style="@style/Button.Outline"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:text="+ إضافة صور"
                    android:textSize="16sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvImageCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="لم يتم اختيار صور"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="16dp">
        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>
    </FrameLayout>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnBackStep"
            style="@style/Button.Outline"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="رجوع"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btnNext"
            style="@style/Button.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="التالي"/>
    </LinearLayout>

</LinearLayout>
